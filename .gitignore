# dependencies
node_modules/

# build output
dist/

# typescript / tsc emitted artifacts
*.tsbuildinfo
vite.config.js
vite.config.d.ts

# python
.venv/
__pycache__/
*.pyc

# env / secrets
.env

# logs
*.log

# local memory (do not sync)
.workbuddy/

# KB seed markdown — NOT authoritative, DB (pgvector) is the source of truth.
# These files live on disk locally for re-ingest only; never track in git.
backend/app/data/markdown/
# uploaded raw files (docx/pdf/md) stored by the parsing pipeline; regenerated on upload
backend/app/data/uploads/
# SSL certs (self-signed, regenerated per machine; private key NEVER in git)
backend/certs/
deploy/nginx/certs/
deploy/nginx/certbot/

# runtime backups (pg_dump output; regenerated, never track)
deploy/backup/*.sql.gz
deploy/backup/*.sql

review/

# interview prep materials (user-only, NEVER commit to git)
interview/

# secrets — global fallback (never commit private keys / certs / macOS cruft)
*.pem
*.key
*.crt
*.pfx
*.key.pem
.DS_Store

# screenshot artifacts from UI review runs
.screenshots/

