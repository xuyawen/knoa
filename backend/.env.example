# ============================================================
# Knoa 生产环境变量模板（backend/.env）
# ------------------------------------------------------------
# 用法：cp backend/.env.example backend/.env  然后改成真实值
# 注意：.env 已被 .gitignore / .dockerignore 排除，绝不进 git 或镜像。
# 本文件 .env.example 可安全提交，用于记录「需要哪些变量」。
#
# compose 启动时会用服务名覆盖下面 DATABASE_URL / REDIS_URL /
# SSL_ENABLED / CORS_ORIGINS / APP_ENV，所以本地这几项注释掉即可。
# ============================================================

# ---------- 数据库 / 缓存（容器内由 compose 覆盖，本地开发再填） ----------
# DATABASE_URL=postgresql+asyncpg://knoa:knoa@localhost:5433/knoa
# REDIS_URL=redis://localhost:6380/0

# ---------- Embedding 模型（OpenAI 兼容 API） ----------
# 当前接入阿里云 DashScope text-embedding-v4（输出 1024 维）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=__FILL_DASHSCOPE_KEY__
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# ---------- LLM（多模态推理，OpenAI 兼容） ----------
# 当前接入 Agnes agnes-2.0-flash（支持 image_url base64 看图）
# 把下面的 BASE_URL 换成你拿到的 Agnes 端点（含 /v1 后缀）
LLM_BASE_URL=https://__FILL_AGNES_ENDPOINT__/v1
LLM_API_KEY=__FILL_AGNES_KEY__
LLM_MODEL=agnes-2.0-flash
LLM_TEMPERATURE=0.3
# ⚠️ 推理模型：max_tokens 太小会被「推理过程」吃光导致回答为空
# 多模态 / 长回答务必 >= 2000
LLM_MAX_TOKENS=2000

# ---------- 模型多模态能力开关（一期只开 image） ----------
# audio / video 切到支持前保持 False，ask 路由层会 400 拦截
MODEL_CAPABILITIES={"image": true, "audio": false, "video": false}

# ---------- 联网搜索（web_search 工具，BoCha → Tavily → DuckDuckGo 兜底） ----------
# 两个都留空则走无 key 的 DuckDuckGo HTML 兜底（沙箱外可能不稳）
BOCHA_API_KEY=__FILL_BOCHA_KEY__
TAVILY_API_KEY=

# ---------- LangSmith 追踪（默认关） ----------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=knoa

# ---------- RAG / 检索 ----------
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_CHUNK_MIN_CHARS=10
RRF_K=60

# ---------- Elasticsearch 混合检索（默认关，未接则不启用） ----------
ES_ENABLED=false

# ---------- 长期记忆 Mem0（自研轻量版，复用 JSONB + numpy） ----------
MEMORY_ENABLED=true
MEMORY_TOP_K=5
MEMORY_SIM_THRESHOLD=0.92

# ---------- 知识图谱 Graph RAG（Postgres 图存储，无需 Neo4j） ----------
GRAPH_ENABLED=true
GRAPH_TOP_K=5

# ---------- 鉴权 RBAC ----------
# ⚠️ 生产必须改成强随机值（openssl rand -hex 32），否则 token 可被伪造
JWT_SECRET=__CHANGE_ME_STRONG_RANDOM__
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PBKDF2_ITERATIONS=100000

# ---------- 初始管理员（首次启动且无任何用户时自动创建） ----------
# ⚠️ 生产必须改密码，默认 admin123 等于裸奔
ADMIN_USERNAME=admin
ADMIN_PASSWORD=__CHANGE_ME_ADMIN_PASSWORD__
ADMIN_DISPLAY_NAME=系统管理员

# ---------- HTTPS / TLS ----------
# 生产由 nginx 反代终止 TLS，backend 容器内明文 HTTP
SSL_ENABLED=false
SSL_CERT_FILE=certs/cert.pem
SSL_KEY_FILE=certs/key.pem

# ---------- 对象存储（文档解析管线） ----------
# local = 落本地磁盘（零依赖）；s3 = MinIO/S3 兼容
OBJECT_STORE=local
OBJECT_STORE_LOCAL_DIR=app/data/uploads

# ---------- App ----------
# 容器内由 compose 覆盖为 production
APP_ENV=production
# ⚠️ 改成你站点的真实 Origin（须与浏览器访问地址完全一致，否则 CORS 报错）
CORS_ORIGINS=https://knoa.example.com
LOG_LEVEL=INFO
