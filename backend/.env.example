# ---- 数据库 (PostgreSQL + pgvector) ----
DATABASE_URL=postgresql+asyncpg://knoa:knoa@localhost:5433/knoa

# ---- Redis ----
REDIS_URL=redis://localhost:6380/0


# ---- LLM (OpenAI-compatible, M3 配置) ----
# 支持 OpenAI / DeepSeek / Moonshot / 通义千问等兼容接口
# DeepSeek:  https://api.deepseek.com/v1  model=deepseek-chat
# OpenAI:    https://api.openai.com/v1    model=gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# ---- LangSmith 追踪 (M4 配置) ----
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=knoa

# ---- RAG 参数 ----
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RRF_K=60

# ---- 应用 ----
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO

# ---- Embedding API (OpenAI-compatible) ----
# 可与 LLM 不同提供商; DeepSeek 无 embeddings, 须用 OpenAI 或其他
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
