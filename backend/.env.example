# ============================================================
# Knoa 后端环境变量样例
# 复制为 backend/.env 后填入真实值（backend/.env 已被 .gitignore 忽略，绝不进 git）
#
# 两种运行环境：
#   - 开发：APP_ENV=development，直接用 vite(5174) 或 frontend:8080，后端可开 HTTPS 自签
#   - 生产：APP_ENV=production，由 deploy/nginx 的 edge 做 TLS 终止，后端跑明文 HTTP
#     （docker-compose.yml 已用 environment 覆盖 DATABASE_URL/REDIS_URL/SSL_ENABLED/
#      CORS_ORIGINS/APP_ENV，你只需在本文件里改下面标注「生产必改」的项）
# ============================================================

# ---- 数据库 (PostgreSQL + pgvector) ----
# 开发本机：postgres 容器把 5432 映射到宿主机 5433
DATABASE_URL=postgresql+asyncpg://knoa:knoa@localhost:5433/knoa
# 生产不必改：docker-compose.yml 会用服务名覆盖为 postgres:5432

# ---- Redis ----
REDIS_URL=redis://localhost:6380/0
# 生产不必改：docker-compose.yml 会覆盖为 redis:6379

# ---- LLM (OpenAI-compatible) ----
# 支持 OpenAI / DeepSeek / Moonshot / 通义千问等兼容接口
# DeepSeek:  https://api.deepseek.com/v1  model=deepseek-chat
# OpenAI:    https://api.openai.com/v1    model=gpt-4o-mini
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# ---- Embedding API (OpenAI-compatible) ----
# 可与 LLM 不同提供商；DeepSeek 无 embeddings，须用 OpenAI 或其他
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-embedding-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- 联网搜索（web_search 工具）----
# 优先 BoCha（中文检索更准），其次 Tavily，二者均留空则走无 key 的 DuckDuckGo HTML 兜底
BOCHA_API_KEY=
TAVILY_API_KEY=

# ---- LangSmith 追踪 ----
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=knoa

# ---- RAG 参数 ----
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RRF_K=60

# ---- Elasticsearch 混合检索（Phase 2，可选）----
# 必须显式 True 才启用；ES 不可用时自动回退 pgvector，绝不因 ES 而崩
ES_ENABLED=False
ES_URL=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX_PREFIX=kb
ES_REQUEST_TIMEOUT=10.0

# ---- 长期记忆 Mem0 轻量自研版（Phase 2 T4）----
MEMORY_ENABLED=True
MEMORY_TOP_K=5
MEMORY_SIM_THRESHOLD=0.92

# ---- 知识图谱 / Graph RAG（Phase 3 T1，Postgres 图存储，无需 Neo4j）----
GRAPH_ENABLED=True
GRAPH_TOP_K=5

# ---- 鉴权 RBAC（Phase 2，【生产必改】）----
# ⚠️ 以下两项生产必须改成强随机值，否则 token 可被伪造、管理员可被冒认
JWT_SECRET=dev-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
PBKDF2_ITERATIONS=100000

# ---- 初始管理员（首次启动、且无任何用户时自动创建；【生产必改】）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=系统管理员

# ---- HTTPS / TLS ----
# 开发：True + 自签证书（backend/certs，Dockerfile 的 entrypoint 会在缺失时生成）
# 生产：False（由 deploy/nginx 的 edge 终止 TLS，后端明文 HTTP）
SSL_CERT_FILE=certs/cert.pem
SSL_KEY_FILE=certs/key.pem
SSL_ENABLED=True

# ---- 对象存储（Phase 3 T3 文档解析管线）----
# local = 落本地磁盘（开发/沙箱默认，零依赖）；s3 = MinIO/S3 兼容（httpx + 手写 SigV4）
OBJECT_STORE=local
OBJECT_STORE_LOCAL_DIR=app/data/uploads
# MinIO / S3（OBJECT_STORE=s3 时生效）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=knoa
MINIO_REGION=us-east-1
MINIO_USE_SSL=False

# ---- 应用 ----
APP_ENV=development
# 后端允许的来源。开发填 vite 地址；【生产填你的域名】，需与站点访问 Origin 一致：
#   docker-compose.yml 的 edge 模式下这里由 compose 覆盖为 https://你的域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO
