# Knoa 生产环境变量
# ===== 使用方法 =====
# 1. 复制本文件为 deploy/.env（或项目根目录 .env）
# 2. 替换所有 change-me / TODO 占位符为真实值
# 3. 本文件已被 .gitignore 忽略，切勿将填入真实密钥的版本提交 git
#
# ===== 生成强随机值命令 =====
# POSTGRES_PASSWORD: openssl rand -hex 24
# JWT_SECRET:         openssl rand -hex 32
# ADMIN_PASSWORD:     用你记得住的强密码（含大小写+数字+符号，12位以上）

# ── 数据库口令（postgres/backup/backend 三方必须一致）──
POSTGRES_PASSWORD=change-me-random-24-hex-chars

# ── 前端访问地址（CORS + nginx server_name）──
# 有域名时用域名：https://knoa.yourdomain.com
# 无域名过渡期用 IP：https://170.106.74.73（需自签证书）或 http://170.106.74.73（不加密）
PUBLIC_IP=170.106.74.73
CORS_ORIGINS=https://170.106.74.73

# ── TLS 选项 ──
# "https" = 用自签或 Let's Encrypt 证书（推荐，即使自签也加密传输）
# "http"  = 纯 HTTP（仅限内网/测试，Cookie Secure 会自动关闭）
TLS_MODE=https
