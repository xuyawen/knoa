# Knoa 生产环境变量示例
# 用法：复制为 deploy/.env（或项目根 .env），填入真实强值后启动生产编排。
# 注意：deploy/.env 与根 .env 均已被 .gitignore 忽略，切勿提交真实密钥。

# ── 数据库口令（postgres 服务 / backend DATABASE_URL / backup 必须一致）──
# 生成强随机口令：  openssl rand -hex 24
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# ── 鉴权（backend/.env 里的开发默认值在生产会被 validate_production_settings 拒绝启动）──
# 直接在 backend/.env（生产用副本）覆盖即可：
# JWT_SECRET=openssl rand -hex 32
# ADMIN_PASSWORD=另一个强随机口令

# ── 可选：为 redis 启用访问口令（需同时在 redis 服务加 --requirepass）──
# REDIS_PASSWORD=openssl rand -hex 16

# ── 对象存储（若用 s3 / minio）──
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
