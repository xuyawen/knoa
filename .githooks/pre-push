#!/bin/sh
# pre-push hook: push 之前本地拦截坏代码，让 CI 永远绿。
#   - frontend/ 改动 → npm run build（vue-tsc 类型检查 + vite build）
#   - backend/  改动 → 本地 postgres 可达时跑 pytest（不可达则告警放行，CI 兜底）
# 仅当对应改动存在时才跑对应检查，纯单一端 push 不浪费时间。
#
# 重要：本机 Windows 上绝不在这个 hook 里跑 `uv run`（会触发 Defender 实时保护
# 锁死 .venv）。前端用 npm、后端用现成的 backend/.venv，都安全。

# Git 通过 stdin 按行传入待推送的 ref：<local_ref> <local_sha> <remote_ref> <remote_sha>
read -r local_ref local_sha remote_ref remote_sha

# 删除分支 / 空推送（remote_sha 全 0）直接放行
if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
  exit 0
fi

changed=$(git diff --name-only "$remote_sha" "$local_sha" 2>/dev/null)
root=$(git rev-parse --show-toplevel)

# ---------- 前端 ----------
case "$changed" in
  *frontend/*)
    echo "[pre-push] 检测到前端改动，运行 build（vue-tsc 类型检查 + vite build）..."
    ( cd "$root/frontend" && npm run build ) || {
      echo "[pre-push] 前端 build 失败，已阻止 push。请修复类型错误后再 push。"
      exit 1
    }
    echo "[pre-push] 前端 build 通过。"
    ;;
esac

# ---------- 后端 ----------
case "$changed" in
  *backend/*)
    # conftest 默认连 localhost:5433；可用 KNOA_TEST_PG_PORT 覆盖
    PG_PORT="${KNOA_TEST_PG_PORT:-5433}"
    if "$root/backend/.venv/Scripts/python.exe" -c \
        "import socket,sys; s=socket.create_connection(('localhost',int(sys.argv[1])),timeout=2); s.close()" \
        "$PG_PORT" >/dev/null 2>&1; then
      echo "[pre-push] 检测到后端改动且本地 postgres(:$PG_PORT) 可达，运行 pytest..."
      ( cd "$root/backend" && "$root/backend/.venv/Scripts/python.exe" -m pytest -q ) || {
        echo "[pre-push] 后端 pytest 失败，已阻止 push。请修复测试后再 push。"
        exit 1
      }
      echo "[pre-push] 后端 pytest 通过。"
    else
      echo "[pre-push] 警告：检测到后端改动，但本地 postgres(:$PG_PORT) 不可达，跳过 pytest（CI 会兜底）。"
    fi
    ;;
esac

exit 0
